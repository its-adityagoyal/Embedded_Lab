                      60     ;-----------------------------------
                      61     ; BLINK MODE ROUTINE
                      62     ;-----------------------------------
814F                  63     BLINK:
                      64         ; 1. Turn ALL OFF
814F C290             65         CLR P1.0
8151 C291             66         CLR P1.1
8153 C292             67         CLR P1.2
8155 C293             68         CLR P1.3
8157 C294             69         CLR P1.4
8159 317B             70         ACALL DELAY1        ; Fast Delay
                      71     
                      72         ; 2. Turn ALL ON
815B D290             73         SETB P1.0
815D D291             74         SETB P1.1
815F D292             75         SETB P1.2
8161 D293             76         SETB P1.3
8163 D294             77         SETB P1.4
8165 317B             78         ACALL DELAY1        ; Fast Delay
                      79     
                      80         ; 3. Check Sensor to Exit
8167 D295             81         SETB P1.5           ; Ensure Input mode is still set
8169 309596           82         JNB P1.5, MAIN_LOOP ; If P1.5 is Low (Open), go back to Main
816C 80E1             83         SJMP BLINK          ; Else, keep blinking
